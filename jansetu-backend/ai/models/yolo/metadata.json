{
    "model_id": "yolov11_det",
    "model_name": "YOLOv11-Detection",
    "runtime": "qnn_dlc",
    "precision": "float",
    "tool_versions": {
        "qairt": "2.45.0.260326154327"
    },
    "model_files": {
        "yolov11_det.dlc": {
            "inputs": {
                "image": {
                    "shape": [
                        1,
                        640,
                        640,
                        3
                    ],
                    "dtype": "float32",
                    "io_type": "image",
                    "image_metadata": {},
                    "value_range": [
                        0.0,
                        1.0
                    ]
                }
            },
            "outputs": {
                "boxes": {
                    "shape": [
                        1,
                        8400,
                        4
                    ],
                    "dtype": "float32",
                    "io_type": "bbox",
                    "bbox_metadata": {}
                },
                "scores": {
                    "shape": [
                        1,
                        8400
                    ],
                    "dtype": "float32",
                    "softmax_applied": true,
                    "labels_file": "coco_labels.txt"
                },
                "class_idx": {
                    "shape": [
                        1,
                        8400
                    ],
                    "dtype": "uint8",
                    "labels_file": "coco_labels.txt"
                }
            }
        }
    },
    "supplementary_files": {
        "labels.txt": "Mapping of model prediction indices -> string labels."
    }
}